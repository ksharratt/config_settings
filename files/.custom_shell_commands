# --- cbc ssh-to-host helper ---------------------------------------------------------
ssh-target-picker() {
  local idx="${1:-1}"   # 1 = first host, 2 = second host, etc.
  local env="$2"        # e.g. Env_nonprod
  local site="$3"       # e.g. Site_dev_1

  # Enable debug by exporting DEBUG=1 (or prefixing: DEBUG=1 ssh-target-picker ...)
  make ansible-list-hosts |
  awk -v IDX="$idx" -v ENV="@${env}:" -v SITE="@${site}:" -v DEBUG="${DEBUG:-0}" '
    function dbg(msg) { if (DEBUG == 1) print "DBG: " msg > "/dev/stderr" }

    BEGIN {
      env_hit=0; site_hit=0; n=0;
      dbg("BEGIN IDX=" IDX " ENV=" ENV " SITE=" SITE)
    }

    {
      # Show every line if you want super noisy debugging:
      # dbg("LINE: [" $0 "] env_hit=" env_hit " site_hit=" site_hit " n=" n)
    }

    # Walk down the tree: ENV -> SITE
    $0 ~ ENV  {
      env_hit=1; site_hit=0; n=0;
      dbg("Matched ENV line: [" $0 "] => env_hit=1 site_hit=0 reset n")
      next
    }

    env_hit && $0 ~ SITE {
      site_hit=1; n=0;
      dbg("Matched SITE line: [" $0 "] => site_hit=1 reset n")
      next
    }

    # Host lines are ones with "--<hostname>" and NOT containing "@"
    site_hit && /--/ && $0 !~ /@/ {
      line=$0
      sub(/.*--/, "", line)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)

      n++
      dbg("Host candidate #" n ": [" line "] from raw [" $0 "]")

      if (n == IDX) {
        dbg("SELECTED idx=" IDX " host=[" line "]")
        print line
        exit
      }
    }

    END {
      dbg("END env_hit=" env_hit " site_hit=" site_hit " hosts_seen=" n)
      if (DEBUG == 1 && n < IDX) dbg("WARNING: Requested IDX " IDX " but only saw " n " hosts under SITE.")
    }
  '
}

