mssh() {
  if (($# < 2)); then
    echo "Usage:    mssh <app> <env> <num>"
    echo "Example:  mssh cbc dev 2"
    return 0
  fi

  app="$1"
  env="$2"
  num="$3"
  shift 3

  ########################################
  # ENV → Site mapping
  ########################################
  case "$env" in
    dev) site="Site_dev_1" environment="Env_nonprod" ;;
    pp1) site="Site_preprod_1" environment="Env_nonprod" ;;
    pp2) site="Site_preprod_2" environment="Env_nonprod" ;;
    prod1) site="Site_prod_1" environment="Env_prod" ;;
    prod2) site="Site_prod_2" environment="Env_prod" ;;
    prod3) site="Site_prod_3" environment="Env_prod" ;;
    *)
      echo "Unknown env: $env" >&2
      reut
      ;;
  esac

  site_re="${site}"
  echo "$site_re"

  ########################################
  # APP → selector mapping
  ########################################
  case "$app" in
    cbc)
      repo="/home/d655605/repos/cbc-manage-instances"
      ;;
    em)
      repo="/home/d655605/repos/em-manage-instances"
      ;;
    onboardpwp)
      repo="/home/d655605/repos/onboardpwp-manage-instances"
      ;;
    capgw)
      repo="/home/d655605/repos/capgw-manage-instances"
      ;;
    oam)
      repo="/home/d655605/repos/oam-manage-instances"
      ;;
    *)
      echo "Unknown app: $app" >&2
      return 3
      ;;
  esac

  ########################################
  # Connection
  ########################################

  cd "$repo" || return 3

  local host
  host="$(ssh-target-picker "${num:-1}" "${environment}" "${site_re}")" || return 3
  echo "Host: $host"

  local log_dir="/home/d655605/session_logs"
  mkdir -p "$log_dir"

  local ts log_file
  ts="$(date +'%Y%m%d-%H%M%S')"
  log_file="${log_dir}/cbc-${env}-${host}-${ts}.log"

  # Record the session without breaking TTY
  script -q -f -a "$log_file" -c "make ssh-to-host LIMIT=${host}"
  cleanlogs

}

