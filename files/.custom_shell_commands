# --- Configure prompt to show current directory name ---
PROMPT_COMMAND='printf "\033]0;%s\007" "${PWD##*/}"'

# --- Logging config ---
export LOG_DIR=~/session_logs
export CLEAN_DIR="$LOG_DIR/clean"
mkdir -p "$LOG_DIR" "$CLEAN_DIR"

alias log="script $LOG_DIR/snippet_$(date +%Y%m%d_%H%M%S).log"

cleanlog() {
  local f="$1"

  if [[ -z "$f" ]]; then
    echo "Usage: cleanlog <logfile>" >&2
    return 2
  fi

  # Require readable file
  if [[ ! -r "$f" ]]; then
    echo "Cannot read $f" >&2
    return 1
  fi

  # If LOG_DIR/CLEAN_DIR are used elsewhere, keep them.
  # If not set, default CLEAN_DIR to the file's directory.
  local log_dir clean_dir
  log_dir="${LOG_DIR:-$(dirname -- "$f")}"
  clean_dir="${CLEAN_DIR:-$log_dir}"

  mkdir -p -- "$clean_dir" || return 1

  local base out tmp
  base="$(basename -- "$f")"

  # Keep your naming convention: foo.log -> foo_clean.log
  if [[ "$base" == *.log ]]; then
    out="$clean_dir/${base%.log}_clean.log"
  else
    out="$clean_dir/${base}_clean.log"
  fi

  # Write to a temp file first (avoids partial output if interrupted)
  tmp="${out}.tmp.$$"

  # Strip CSI/SGR etc. with ansifilter, then strip OSC title sequences (ESC ] ... BEL/ESC\)
  # Use > (overwrite) rather than >> (append) for single-file clean to avoid duplication.
  if ansifilter <"$f" | perl -pe 's/\e\][0-9];.*?(\a|\e\\)//g' >"$tmp"; then
    mv -f -- "$tmp" "$out" && rm -f -- "$f"
    echo "Cleaned: $f -> $out"
    return 0
  else
    rm -f -- "$tmp"
    echo "Failed to clean $f" >&2
    return 1
  fi
}

cleanlogs() {
  shopt -s nullglob
  local f
  for f in "$LOG_DIR"/*.log; do
    cleanlog "$f"
  done
}


# --- cheat-sheet config ---
CHEATS_DIR="${HOME}/.config/cheats"
mkdir -p "${CHEATS_DIR}"

cheat() {
  local dir="${CHEATS_DIR}"
  local query="$1"

  if command -v fzf >/dev/null 2>&1; then
    local file
    if [[ -n "$query" ]]; then
      # Find best match using fzf in non-interactive mode
      file="$(printf '%s\n' "$dir"/*.md | fzf --filter="$query" --select-1 --exit-0)"
    else
      # Interactive mode
      file="$(printf '%s\n' "$dir"/*.md | fzf --prompt='cheat> ' --height=40%)"
    fi

    [[ -n "$file" ]] && bat --style=plain --paging=never --color=always -- "$file"
  else
    echo "fzf not installed. Please install fzf."
  fi
}

alias kb='cheat'


# --- doing script --- 
#
# for simple tracking with taskwarrior
#
doing() {

    # Stop any currently active task
    task +ACTIVE stop

    # Add a new task and capture its ID (strip the trailing '.')
    if [ -n "$TW_ACTIVE_PROJ" ]; then
        task_id=$(task add "$*" proj:"$TW_ACTIVE_PROJ" | awk '/Created task/{gsub(/\./,"",$3); print $3}')
    else
        task_id=$(task add "$*" | awk '/Created task/{gsub(/\./,"",$3); print $3}')
    fi

    # Start the new task
    [ -n "$task_id" ] && task "$task_id" start
}

tproj() {
    export TW_ACTIVE_PROJ="$*"
    echo "Active project set to: $TW_ACTIVE_PROJ"
}

alias d='doing'

