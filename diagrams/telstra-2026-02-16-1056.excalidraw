    {
      "id": "TSmc9a1POu4VMHjFawMKX",
      "type": "text",
      "x": 7903.112641834074,
      "y": 141.72371221197818,
      "width": 1177,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e9ecef",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1z",
      "roundness": null,
      "seed": 842571031,
      "version": 875,
      "versionNonce": 748826209,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773130943639,
      "link": null,
      "locked": false,
      "text": "- oracle db should be active at both sites, secondary site as a standby\n- secondary site will have pcs disabled on services if rsmon has detected a failure and forced them down to\nperfom the failover.\n\n- configure_geored_standby.yml - to put oracle database in standby mode, for secondary site\n- oramgr status - check if the database is active or standby\n    this must be run using `sudo su` then `oramgr status` sudo alone doesn't work\n- cbc_nrf needs to be in disabled state on the inactive site, otherwise pcs behavour isn't stable\n   pcs resource disable cbc_nrf\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "w1JUQY6oSn_1XZdG4qrMD",
      "originalText": "- oracle db should be active at both sites, secondary site as a standby\n- secondary site will have pcs disabled on services if rsmon has detected a failure and forced them down to perfom the failover.\n\n- configure_geored_standby.yml - to put oracle database in standby mode, for secondary site\n- oramgr status - check if the database is active or standby\n    this must be run using `sudo su` then `oramgr status` sudo alone doesn't work\n- cbc_nrf needs to be in disabled state on the inactive site, otherwise pcs behavour isn't stable\n   pcs resource disable cbc_nrf\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
