    {
      "id": "ukqFK4P9Tz-XH8A2G7064",
      "type": "text",
      "x": -5159.352018784583,
      "y": 990.6839466891117,
      "width": 1089,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fff9db",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
